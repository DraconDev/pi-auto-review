{
  "name": "pi-auto-review",
  "version": "1.4.0",
  "description": "Automated project review for Pi — scans for problems, writes TODO.md, and optionally auto-fixes in bounded fix loops",
  "keywords": ["pi-package", "auto-review", "code-quality"],
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "echo 'Nothing to build — Pi loads TypeScript directly'",
    "test": "echo 'No tests yet'",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf node_modules"
  },
  "pi": {
    "extensions": ["./extensions"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dracon/pi-auto-review"
  },
  "author": "Dracon"
}